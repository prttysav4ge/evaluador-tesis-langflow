# ============================================
# POC: Evaluador de Tesis - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# ----- SERVIDOR -----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ----- LANGFLOW -----
# Langflow corre localmente con Docker en el puerto 7860
USE_LANGFLOW=true
LANGFLOW_URL=http://localhost:7860
LANGFLOW_FLOW_ID=
LANGFLOW_API_KEY=

# ----- PROVEEDOR LLM (modo Python puro — solo aplica si USE_LANGFLOW=false) -----
# Si USE_LANGFLOW=true, estas variables son ignoradas porque los agentes corren en Langflow.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ----- EMBEDDINGS -----
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ----- CHROMADB -----
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=academic_thesis

# ----- RAG -----
# Número de chunks a recuperar por consulta
TOP_K=5

# ----- CHUNKING -----
CHUNK_SIZE=800
CHUNK_OVERLAP=150
